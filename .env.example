# CLAP Desktop — environment variables
#
# Copy this file to .env and fill in values as needed.
# .env is gitignored; .env.example is committed.

# Set to "development" to enable DevTools, hot-reload, and .venv Python backend.
# Set to "production" (or leave unset) to use the bundled PyInstaller backend.
NODE_ENV=development

# Optional: override the directory where CLAP model weights are searched.
# In production this is auto-resolved relative to the bundled executable.
# CLAP_MODELS_DIR=/path/to/models

# Optional: override the default data directory shown on first launch.
# CLAP_WORKSPACE=/path/to/workspace
